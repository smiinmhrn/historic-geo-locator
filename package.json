{
  "name": "job-seeker-front-end",
  "version": "1.0.0",
  "main": "script.js",
  "scripts": {
    "watch:sass": "node-sass sass/main.scss css/style.css -w",
    "dev-server": "live-server",
    "start": "npm-run-all --parallel dev-server",
    "compile:sass": "node-sass sass/main.sass css/style.css",
    "concat:css": "concat -o css/style.concat.css css/style.css",
    "prefix:css": "postcss --use autoprefixer -b 'last 10 version' css/style.concat.css css/.style.prefix.css",
    "compress:css": "node-sass css/style.prefix.css css/style.css --output-style compressed",
    "build:css": "npm-run-all compile:sass concat:css prefix:css compress:css"
  },
  "author": "Mohsen Gholami",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.15",
    "concat": "^1.0.3",
    "node-sass": "^9.0.0",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^10.1.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "live-server": "^1.2.0"
  }
}
